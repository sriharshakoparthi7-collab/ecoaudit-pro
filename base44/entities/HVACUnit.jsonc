      "type": "string",
      "title": "Make"
    },
    "photo": {
      "type": "string",
      "title": "Photo"
    },
    "location": {
      "type": "string",
      "title": "Location"
    },
    "type": {
      "type": "string",
      "enum": [
        "Packaged",
        "Split"
      ],
      "title": "Type"
    },
    "model": {
      "type": "string",
      "title": "Model"
    },
    "serial_number": {
      "type": "string",
      "title": "Serial Number"
    },
    "heating_capacity_kw": {
      "type": "number",
      "title": "Heating Capacity (kW)"
    },
    "cooling_capacity_kw": {
      "type": "number",
      "title": "Cooling Capacity (kW)"
    },
    "power_supply_phase": {
      "type": "string",
      "title": "Power Supply Phase"
    },
    "nameplate_photos": {
      "type": "string",
