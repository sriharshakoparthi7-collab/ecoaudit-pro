    "controller_type": {
      "type": "string",
      "title": "Controller Type"
    },
    "controller_model": {
      "type": "string",
      "title": "HVAC Controller Model Number"
    },
    "controller_photo": {
      "type": "string",
      "title": "HVAC Controller Photo"
